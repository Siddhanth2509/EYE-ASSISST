# EYE-ASSISST — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# For local development the defaults below work out of the box.

# Backend API URL
# Default: http://127.0.0.1:8000 (used automatically if this var is not set)
# Change this when deploying to a remote server.
VITE_API_URL=http://127.0.0.1:8000
